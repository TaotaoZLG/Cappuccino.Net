@using Cappuccino.Web.Core

@{
    Layout = null;
}

<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <title>Cappuccino</title>
    <!-- 依 赖 样 式 -->
    <link href="~/Content/component/pear/css/pear.css" rel="stylesheet" />
    <!-- 加 载 样 式-->
    <link href="~/Content/admin/css/load.css" rel="stylesheet" />
    <!-- 布 局 样 式 -->
    <link href="~/Content/admin/css/admin.css" rel="stylesheet" />
    <!-- 主 题 更 换 -->
    <style id="pearadmin-bg-color"></style>
</head>
<!-- 结 构 代 码 -->
<body class="layui-layout-body pear-admin">
    <!-- 布 局 框 架 -->
    <div class="layui-layout layui-layout-admin">
        <div class="layui-header">
            <!-- 顶 部 左 侧 功 能 -->
            <ul class="layui-nav layui-layout-left">
                <li class="layui-nav-item">
                    <a href="javascript:;" class="layui-icon layui-icon-shrink-right" pear-event="collaspe" title="侧边伸缩"></a>
                </li>
                <li class="layui-nav-item">
                    <a href="javascript:;" class="layui-icon layui-icon-refresh-1" pear-event="refresh" title="刷新"></a>
                </li>
            </ul>
            <!-- 顶 部 右 侧 菜 单 -->
            <div id="control" class="layui-layout-control"></div>
            <ul class="layui-nav layui-layout-right">
                <li class="layui-nav-item layui-hide-xs">
                    <a href="javascript:;" class="layui-icon layui-icon-notice" menu-url="@Url.Content("/SystemManage/SysMessage/Index")" menu-id="435818600364904448" menu-title="消息中心">
                        <span class="layui-badge-dot"></span>
                    </a>
                </li>
                <li class="layui-nav-item layui-hide-xs">
                    <a href="javascript:;" class="layui-icon layui-icon-theme" pear-event="theme"></a>
                </li>
                <li class="layui-nav-item layui-hide-xs">
                    <a href="javascript:;" class="layui-icon layui-icon-screen-full" pear-event="fullScreen"></a>
                </li>
                <li class="layui-nav-item layui-hide-xs">
                    <a href="http://www.baidu.com/" target="_blank" class="layui-icon layui-icon-website"></a></li>
                <li class="layui-nav-item">
                    <!-- 头 像 -->
                    <a href="javascript:;">
                        <img src="@UserManager.GetCurrentUserInfo().HeadIcon" class="layui-nav-img" id="userPortrait" onerror="this.src=&#39;/Content/images/timg.jpg&#39;">
                        @UserManager.GetCurrentUserInfo().NickName
                    </a>
                    <!-- 功 能 菜 单 -->
                    <dl class="layui-nav-child">
                        <dd><a href="javascript:;" menu-url="@Url.Action("Person","Account")" menu-id="5552" menu-title="个人中心">个人中心</a></dd>
                        <dd><a href="javascript:;" menu-url="@Url.Action("ChangePassword","Account")" menu-id="5553" menu-title="修改密码">修改密码</a></dd>
                        <hr style="margin:5px 0;" />
                        <dd><a href="@Url.Action("Logout","Account")">注销登录</a></dd>
                    </dl>
                </li>
                <li class="layui-nav-item">
                    <a href="javascript:;" class="layui-icon layui-icon-more-vertical"></a>
                </li>
            </ul>
        </div>
        <!-- 侧 边 区 域 -->
        <div class="layui-side layui-bg-black">
            <!-- 顶 部 图 标 -->
            <div class="layui-logo">
                <img class="logo" />
                <span class="title"></span>
            </div>
            <!-- 侧 边 菜 单 -->
            <div class="layui-side-scroll">
                <div id="sideMenu"></div>
            </div>
        </div>
        <!-- 视 图 页 面 -->
        <div class="layui-body">
            <div id="content"></div>
        </div>
    </div>
    <!-- 遮 盖 层 -->
    <div class="pear-cover"></div>
    <!-- 加 载 动 画-->
    <div class="loader-main">
        <div class="loader"></div>
    </div>
    <!-- 依 赖 脚 本 -->
    <script src="~/Content/component/layui/layui.js"></script>
    <script src="~/Content/component/pear/pear.js"></script>
    <script src="~/Content/admin/js/cap-data.js"></script>
    <!-- 框 架 初 始 化 -->
    <script>
        layui.use(['admin'], function () {
            var admin = layui.admin;

            admin.render();
        })
    </script>
</body>
</html>
