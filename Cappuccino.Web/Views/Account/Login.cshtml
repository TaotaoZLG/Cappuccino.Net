@model Cappuccino.Model.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Cappuccino - 登录</title>
    <link rel="stylesheet" href="~/Content/component/pear/css/pear.css" />
    <link rel="stylesheet" href="~/Content/admin/css/other/login.css" />
</head>

<!-- 代 码 结 构 -->
<body background="~/Content/admin/images/background.svg">
    <form class="layui-form" action="javascript:void(0);" lay-filter="formLogon">
        <div class="layui-form-item">
            <img class="logo" src="~/Content/admin/images/logo.png" />
            <div class="title">Cappuccino</div>
            @*<div class="desc">
                ASP.NET MVC 5 + Entity Framework 6
            </div>*@
        </div>
        <div class="demo-login-container">
            <div class="layui-form-item">
                <div class="layui-form-item">
                    <div class="input-wrap">
                        <i class="layui-icon layui-icon-username input-icon"></i>
                        <input type="text" name="LoginName" value="@Model.LoginName" lay-verify="required" lay-reqtext="请输入用户名" placeholder="用户名" autocomplete="off" class="layui-input" />
                    </div>
                </div>
            </div>
            <div class="layui-form-item">
                <div class="input-wrap">
                    <i class="layui-icon layui-icon-password input-icon"></i>
                    <input type="password" name="LoginPassword" lay-verify="required" lay-reqtext="请输入密码" placeholder="密  码 " autocomplete="off" class="layui-input" />
                </div>
            </div>
            <div class="layui-form-item verify-code-group">
                <div class="input-wrap">
                    <i class="layui-icon layui-icon-vercode input-icon"></i>
                    <input type="text" name="VerifyCode" lay-verify="required" lay-reqtext="请输入验证码" placeholder="验证码" autocomplete="off" class="code layui-input layui-input-inline" />
                </div>
                <img src="/Account/CreateVerifyCode" alt="验证码" class="codeImage" onclick="resetVCode()" />
            </div>
            <div class="layui-form-item">
                <input type="checkbox" name="IsMember" value="true" title="记住密码" lay-filter="RememberMe" lay-skin="primary" @(Model.IsMember ? "checked" : "")>
            </div>
            <div class="layui-form-item">
                <button id="btnLogin" class="pear-btn pear-btn-success login" lay-submit lay-filter="login">登 录</button>
            </div>
        </div>
    </form>
    <!-- 资 源 引 入 -->
    <script src="~/Content/component/layui/layui.js"></script>
    <script src="~/Content/component/pear/pear.js"></script>
    <script>
        layui.use(['form', 'element', 'jquery', 'common', 'popup'], function () {
            var form = layui.form;
            var element = layui.element;
            var common = layui.common;
            var popup = layui.popup;
            var $ = layui.jquery;

            // 登 录 提 交
            form.on('submit(login)', function (data) {
                common.ajax("@Url.Action("Login","Account")", "post", data.field, true, true).done(function (response) {
                    window.location = "/Home";
                    //popup.success("登录成功", function() {
                    //  window.location = "/Home";
                    //});
                }).fail(function (error) {
                    console.log(error)
                    //刷新二维码
                    resetVCode()
                });

                return false;
            });

            //刷新验证码
            window.resetVCode = function () {
                var url = "@Url.Action("CreateVerifyCode","Account")?rid=" + Math.random()
                $(".codeImage").attr("src", url);
            };
        });
    </script>
</body>
</html>

