@model Cappuccino.Model.SysUserModel
@{
    ViewBag.Title = "Person";
    Layout = "~/Views/Shared/_LayoutIndex.cshtml";
}
@using Cappuccino.Web.Core
@section Style{
    <link href="~/Content/admin/css/other/person.css" rel="stylesheet" />
}
<div class="layui-row layui-col-space10">
    <div class="layui-col-md3">
        <div class="layui-card">
            <div class="layui-card-body" style="padding: 25px 25px 5px 25px;">
                <div class="text-center layui-text">
                    <div class="user-info-head" id="userInfoHead">
                        <img src="@UserManager.GetCurrentUserInfo().HeadIcon" id="userAvatar" width="115px" height="115px" alt="用户头像">
                    </div>
                    <h2 style="padding-top: 20px;font-size: 20px;">@UserManager.GetCurrentUserInfo().NickName</h2>
                </div>
                <div>
                    <ul class="user-info-list">
                        <li class="user-info-item">
                            <span class="info-label">登录名称:</span>
                            <span class="info-value">@UserManager.GetCurrentUserInfo().UserName</span>
                        </li>
                        <li class="user-info-item">
                            <span class="info-label">手机号码:</span>
                            <span class="info-value">@UserManager.GetCurrentUserInfo().MobilePhone</span>
                        </li>
                        <li class="user-info-item">
                            <span class="info-label">所属部门:</span>
                            <span class="info-value">@UserManager.GetCurrentUserInfo().DepartmentName</span>
                        </li>
                        <li class="user-info-item">
                            <span class="info-label">邮箱地址:</span>
                            <span class="info-value">@UserManager.GetCurrentUserInfo().Email</span>
                        </li>
                        <li class="user-info-item">
                            <span class="info-label">创建时间:</span>
                            <span class="info-value">@UserManager.GetCurrentUserInfo().CreateTime.Value.ToString("yyyy-MM-dd")</span>
                        </li>
                    </ul>
                </div>
                <div style="height: 45px;border-top: 1px whitesmoke solid;text-align: center;line-height: 45px;font-size: 13.5px;">
                    <span>今日事 ，今日毕</span>
                </div>
            </div>
        </div>
    </div>
    <div class="layui-col-md9">
        <div class="layui-card">
            <div class="layui-card-header">
                我的相关
            </div>
            <div class="layui-card-body">
                <div class="layui-tab" lay-filter="docDemoTabBrief">
                    <ul class="layui-tab-title">
                        <li class="layui-this">基本资料</li>
                        <li>我的文章</li>
                    </ul>
                    <div class="layui-tab-content" style="height: 500px;">
                        <div class="layui-tab-item layui-show">
                            <div class="layui-row layui-col-space10">
                                <form class="layui-form" lay-filter="formEdit">
                                    <div class="main-container">
                                        <div class="layui-form-item">
                                            <label class="layui-form-label">昵称</label>
                                            <div class="layui-input-inline">
                                                <input type="text" name="nickName" lay-verify="required" autocomplete="off" placeholder="请输入昵称" class="layui-input" value="@Model.NickName">
                                            </div>
                                        </div>
                                        <div class="layui-form-item">
                                            <label class="layui-form-label">手机号码</label>
                                            <div class="layui-input-inline">
                                                <input type="text" lay-verify="phone" name="mobilePhone" autocomplete="off" placeholder="请输入号码" class="layui-input" value="@Model.MobilePhone">
                                            </div>
                                        </div>
                                        <div class="layui-form-item">
                                            <label class="layui-form-label">邮箱</label>
                                            <div class="layui-input-inline">
                                                <input type="text" lay-verify="email" name="email" autocomplete="off" placeholder="请输入邮箱" class="layui-input" value="@Model.Email">
                                            </div>
                                        </div>
                                        <div class="layui-form-item">
                                            <div class="layui-input-block">
                                                <button type="submit" class="layui-btn layui-btn-normal layui-btn-sm" lay-submit="" lay-filter="editUser">
                                                    <i class="layui-icon layui-icon-ok"></i>提交
                                                </button>
                                                <button type="reset" class="layui-btn layui-btn-primary layui-btn-sm">
                                                    <i class="layui-icon layui-icon-refresh"></i>重置
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <div class="layui-tab-item">
                            <div class="layui-row layui-col-space10" style="margin: 15px;">
                                <div class="layui-col-md1">
                                    <img src="~/Content/admin/images/act.jpg" style="width: 100%;height: 100%;border-radius: 5px;" />
                                </div>
                                <div class="layui-col-md11" style="height: 80px;">
                                    <div class="title">为什么程序员们愿意在GitHub上开源自己的成果给别人免费使用和学习？</div>
                                    <div class="content">
                                        “Git的精髓在于让所有人的贡献无缝合并。而GitHub的天才之处，在于理解了Git的精髓。”来一句我们程序员们接地气的话：分享是一种快乐~
                                    </div>
                                    <div class="comment">2020-06-12 &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; 评论 5 点赞 12 转发 4</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        layui.use(['form', 'jquery', 'layer', 'element'], function () {
            var form = layui.form;
            var $ = layui.jquery;
            var layer = layui.layer;
            var element = layui.element;

            // 点击头像弹出裁剪弹窗
            $('#userInfoHead').on('click', function () {
                layer.open({
                    type: 2,
                    title: '修改头像',
                    content: '/SystemManage/SysUser/Portrait',
                    area: ['870px', '580px'],
                });
            });

            form.on("submit(editUser)", function (data) {
                //common.ajax("/SystemManage/SysUser/Edit", "post", data.field, true, true).done(function (response) {
                //    layer.msg(response.message, { icon: 1, time: 1000 }, function () {
                //    });
                //}).fail(function (error) {
                //    console.log(error)
                //});
                return false;
            });
        })
    </script>
}