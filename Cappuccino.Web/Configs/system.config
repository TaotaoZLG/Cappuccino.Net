<?xml version="1.0" encoding="utf-8"?>
<appSettings>
  <add key="webpages:Version" value="3.0.0.0" />
  <add key="webpages:Enabled" value="false" />
  <add key="ClientValidationEnabled" value="true" />
  <add key="UnobtrusiveJavaScriptEnabled" value="true" />
  <!-- ================== 1：log4net日志相关配置 ================== -->
  <add key="log4net.Config" value="Configs/log4net.config"/>
  <add key="log4net.Config.Watch" value="True" />
  <!-- ================== 2：开发系统相关配置 ================== -->
  <!-- 缓存类型 可选值:"Memory"(默认)，"Memory"，"Redis"，"HttpRuntime" -->
  <add key="CacheType" value="Redis" />
  <!-- 连接字符串格式：IP:端口,password=密码,defaultDatabase=数据库编号,abortConnect=false -->
  <add key="RedisConnectionString" value="localhost:6379,password=,defaultDatabase=0,abortConnect=false" />

  <!-- 上传文件大小 -->
  <add key="UploadFileByImgSize" value="2048" />
  <!-- 上传文件类型 -->
  <add key="UploadFileByImgType" value="png|gif|jpg|jpeg" />
  <!-- 数据库备份文件保存路径 -->
  <add key="DbBackupPath" value="" />
  <!-- 虚拟目录 -->
  <add key="VirtualDirectory" value="/Resource" /> 
  <!-- 雪花算法配置 -->
  <!-- 单机开发环境：WorkerId 设为 1 即可 -->
  <!-- 生产环境多机部署：服务器A设为1，服务器B设为2，以此类推 -->
  <add key="Snowflake.WorkerId" value="1" />
  <add key="Snowflake.DatacenterId" value="1" />

  <!-- 压缩包/文件配置 -->
  <!-- 压缩包支持格式 -->
  <add key="CompressSupportFormats" value="zip,rar,7z,xls,xlsx" />
  <!-- 图片支持格式 -->
  <add key="FileSupportFormats" value="jpg,jpeg,png,bmp,gif,tiff" />
  <!-- 上传文件大小限制（100MB） -->
  <add key="UploadMaxFileSize" value="104857600" />
  <!-- 临时文件根目录 -->
  <add key="TempRootPath" value="/Resource/FileProcessiong/CompressTemp/" /> 
  <!-- 归档文件根目录 -->
  <add key="ArchiveRootPath" value="/Resource/FileProcessiong/ArchiveTemp/" />
  <!-- 导出文件根目录 -->
  <add key="ExportRootPath" value="/Resource/FileProcessiong/ExportTemp/" />
  <!-- 临时文件清理超时（分钟） -->
  <add key="TempFileExpireMinutes" value="30" />
  
  <!-- AI服务配置 -->
  <add key="AIService" value="http://localhost:8000/api/ocr" />
  <add key="AITimeout" value="30000" />
</appSettings>