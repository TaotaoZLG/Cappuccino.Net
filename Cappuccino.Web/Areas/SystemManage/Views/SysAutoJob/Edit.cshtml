@model Cappuccino.Model.SysAutoJobModel
@{
    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_LayoutForm.cshtml";
}
<form class="layui-form" lay-filter="formEdit">
    @Html.HiddenFor(x => x.Id)
    <div class="mainBox">
        <div class="main-container">
            <div class="layui-form-item">
                <label class="layui-form-label">任务名称</label>
                <div class="layui-input-block">
                    <input type="text" name="JobName" lay-verify="required" autocomplete="off" placeholder="请输入任务名称" class="layui-input" value="@Model.JobName">
                </div>
            </div>
            <div class="layui-form-item">
                <label class="layui-form-label">任务分组</label>
                <div class="layui-input-block">
                    <input type="text" name="JobGroup" class="layui-input" value="@Model.JobGroup">
                </div>
            </div>
            <div class="layui-form-item">
                <label class="layui-form-label">Cron表达式 <span class="layui-red">*</span></label>
                <div class="layui-input-block">
                    <input type="text" name="CronExpression" lay-verify="required" placeholder="例如：0 0/5 * * * ?" class="layui-input" value="@Model.CronExpression">
                    <div class="layui-form-mid layui-word-aux">Cron表达式生成工具：<a href="https://cron.qqe2.com/" target="_blank">点击访问</a></div>
                </div>
            </div>
            <div class="layui-form-item">
                <label class="layui-form-label">执行类名 <span class="layui-red">*</span></label>
                <div class="layui-input-block">
                    <input type="text" name="JobClassName" lay-verify="required" placeholder="包含命名空间的完整类名" class="layui-input" value="@Model.JobClassName">
                    <div class="layui-form-mid layui-word-aux">例如：Cappuccino.Web.Tasks.SampleTask</div>
                </div>
            </div>
            <div class="layui-form-item">
                <label class="layui-form-label">开始时间</label>
                <div class="layui-input-block">
                    <input type="text" name="StartTime" placeholder="请选择开始时间" class="layui-input time-input" data-type="datetime" value="@Model.StartTime">
                </div>
            </div>

            <div class="layui-form-item">
                <label class="layui-form-label">结束时间</label>
                <div class="layui-input-block">
                    <input type="text" name="EndTime" placeholder="请选择结束时间" class="layui-input time-input" data-type="datetime" value="@Model.EndTime">
                </div>
            </div>
            @Html.EnabledMarkRadioHtml("JobStatus")
            <div class="layui-form-item">
                <label class="layui-form-label">任务描述</label>
                <div class="layui-input-block">
                    <textarea name="Description" class="layui-textarea" value="@Model.Description"></textarea>
                </div>
            </div>
        </div>
    </div>
    <div class="bottom">
        <div class="button-container">
            <button type="submit" class="layui-btn layui-btn-normal layui-btn-sm" lay-submit="" lay-filter="edit">
                <i class="layui-icon layui-icon-ok"></i>
                提交
            </button>
            <button type="reset" class="layui-btn layui-btn-primary layui-btn-sm">
                <i class="layui-icon layui-icon-refresh"></i>
                重置
            </button>
        </div>
    </div>
</form>
@section Scripts {
    <script>
        layui.use(['form', 'jquery', 'common'], function () {
            let form = layui.form;
            let $ = layui.jquery;
            let common = layui.common;

            form.on("submit(edit)", function (data) {
                common.ajax("/SystemManage/SysAutoJob/Edit", "post", data.field, true, true).done(function (response) {
                    layer.msg(response.message, { icon: 1, time: 1000 }, function () {
                        parent.layer.close(parent.layer.getFrameIndex(window.name));//关闭当前页
                        parent.layui.table.reload("tableId");
                    });
                    }).fail(function (error) {
                        console.log(error)
                    });
                    return false;
                });
            });

    </script>
}

